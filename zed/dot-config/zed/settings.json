// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "colorize_brackets": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "always_treat_brackets_as_autoclosed": true,
  "toolbar": {
    "code_actions": false,
  },
  "minimap": {
    "show": "never",
  },
  "prettier": {
    "parser": "",
  },
  "vim": {
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": true,
  },
  "inlay_hints": {
    "enabled": true,
  },
  "cli_default_open_behavior": "existing_window",
  "icon_theme": "VSCode Icons for Zed (Dark)",
  "ui_font_family": "CommitMono Nerd Font Propo",
  "buffer_font_family": "CommitMono Nerd Font",
  "terminal": {
    "font_family": "CommitMono Nerd Font Mono",
  },
  "diff_view_style": "split",
  "semantic_tokens": "combined",
  "cursor_blink": false,
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "title_bar": {
    "show_user_picture": false,
    "show_user_menu": true,
    "show_menus": false,
    "show_sign_in": false,
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "proxy": "",
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        "token_type": "*.mutable",
        "token_modifiers": [],
        "style": [],
        "foreground_color": null,
        "background_color": null,
        "underline": null,
        "strikethrough": null,
        "font_weight": null,
        "font_style": null,
      },
    ],
  },
  "lsp": {
    "clangd": {
      "binary": {
        "arguments": ["-compile-commands-dir=build"],
      },
    },
  },
  "base_keymap": "VSCode",
  "soft_wrap": "editor_width",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro",
  },
  "theme_overrides": {
    "One Dark Pro": {
      "accents": ["#d19a66", "#c678dd", "#56b6c2"],
      "syntax": {
        "comment": { "font_style": "italic" },
        "namespace": { "color": "#56b6c2" },
        "operator": { "color": "#56b6c2" },
        "string.escape": { "color": "#7681de" },
        "type.builtin": { "color": "#7681de" },
      },
    },
  },
}
