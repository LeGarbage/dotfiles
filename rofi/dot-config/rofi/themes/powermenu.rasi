@import "common"

window {
    width: 940;
}

mainbox {
    children: [ listview ];
}

listview {
    columns: 5;
    lines: 1;
}

element {
    orientation: vertical;
    horizontal-align: 0.5;
    padding: 30px;
    spacing: 8px; 
}

element-icon {
    size: 5em;
    horizontal-align: 0.5;
}

element-text {
    font: "CommitMonoNerdFont 16";
    horizontal-align: 0.5;
}
